/mvnw text eol=lf
*.cmd text eol=crlf

# Auto-detect text files and normalize line endings
* text=auto

# Java & config files — always LF in repo
*.java text eol=lf
*.xml  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.properties text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.sql  text eol=lf

# Windows batch files — keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files — no conversion
*.jar  binary
*.war  binary
*.class binary
*.png  binary
*.jpg  binary
*.ico  binary
